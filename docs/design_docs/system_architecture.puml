@startuml
!theme plain
skinparam componentStyle rectangle

' TIER 1: CLIENT TIER (PRESENTATION)
package "1. Client Tier (Presentation)" {
    [Vue.js Web App] as WEB
    [Flutter Mobile App] as MOB
    [Tauri Desktop App] as DSK
}

' TIER 2: SERVER TIER (LOGIC, DATA & INFRA)
' This tier follows a 4-Layer Architecture pattern internally.
node "2. Server Tier (FastAPI Backend)" as SERVER {
    
    package "Layer 1: Presentation Layer" {
        [FastAPI Controllers / REST API]
        note right: Handles RESTful API requests/responses\n(auth, interview, resume, job, admin)
    }
    
    package "Layer 2: Application/Business Layer" {
        [Business Logic Services]
        note right: AI Interview Engine, RAG Retrieval,\nResume Parsing, Email Notifications
    }
    
    package "Layer 3: Data Access Layer" {
        [Domain Models & DB Drivers]
        note right: Uses Motor (Async MongoDB Driver) to\ncommunicate with the Infrastructure Layer.
    }

    package "Layer 4: Infrastructure Layer" {
        database "MongoDB Atlas (Cloud)" as DB
        [Nginx & Uvicorn] as SRV
        [External API Services] as EX_API
        note right: Manages Data Persistence (MongoDB),\nServer Runtime (Uvicorn), and\nExternal Integrations (Mistral, EmailJS)
    }
}

' Relationships
WEB --(0-- SERVER : REST API (JSON)
MOB --(0-- SERVER : REST API (JSON)
DSK --(0-- SERVER : REST API (JSON)

SERVER --> DB : Async CRUD Operations
SERVER --> EX_API : External Requests
@enduml
